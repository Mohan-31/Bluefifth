# ============================================================
# BLUEFIFTH E-COMMERCE — Environment Variables Template
#
# Copy to .env and fill in real values.
# Add .env to .gitignore — NEVER commit real credentials.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_URL=http://localhost/ecommerce-project
APP_NAME=bluefifth
APP_ENV=development         # development | production
APP_DEBUG=false

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=ecommerce_referral_db
DB_USER=root
DB_PASS=                    # use a strong password in production

# ── Razorpay Magic Checkout ──────────────────────────────────
# Primary checkout, payment gateway, and customer identity provider.
# Authentication is handled natively by Razorpay during payment.
# Keys are stored in the admin settings panel (not env vars) —
# set them at: /admin/settings.php > Payment tab.
# rzp_test_* for development, rzp_live_* for production.
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=

# ── Google OAuth (DEPRECATED) ─────────────────────────────────
# Google Sign-In has been removed. Razorpay Magic Checkout is used.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── SendinBlue (Brevo) Email ─────────────────────────────────
SENDINBLUE_API_KEY=
SENDINBLUE_FROM_EMAIL=info@yourdomain.com
SENDINBLUE_FROM_NAME=Your Site Name

# ── Shiprocket ───────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
# Run setup-admin-password.php to set the admin bcrypt hash
