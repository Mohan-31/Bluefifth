# ============================================================
# BLUEFIFTH — Environment Variables Template
#
# Copy this file to .env and fill in your real values.
# .env is gitignored — NEVER commit it with real credentials.
# ============================================================

# ── Application ──────────────────────────────────────────────
# XAMPP local:  BASE_URL=http://localhost/ecommerce-project  BASE_PATH=/ecommerce-project
# Production:   BASE_URL=https://yourdomain.com              BASE_PATH=
BASE_URL=http://localhost/ecommerce-project
BASE_PATH=/ecommerce-project
SITE_NAME=Bluefifth
APP_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=ecommerce_referral_db
DB_USER=root
DB_PASSWORD=

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=your@email.com

# ── Brevo / Sendinblue Email ─────────────────────────────────
SENDINBLUE_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDINBLUE_FROM_EMAIL=info@yourdomain.com
SENDINBLUE_FROM_NAME=Your Site Name

# ── Shiprocket Webhook Tokens ─────────────────────────────────
# Must match what you register in the Shiprocket dashboard.
SHIPROCKET_ORDER_WEBHOOK_TOKEN=change_this_to_a_strong_secret
SHIPROCKET_RETURN_WEBHOOK_TOKEN=change_this_to_a_strong_secret

# ── Razorpay ─────────────────────────────────────────────────
# Keys are stored in DB (Admin Panel > Settings > Payment).
# Test:  rzp_test_xxxxxxxxxxxxxxxxxxxx
# Live:  rzp_live_xxxxxxxxxxxxxxxxxxxx

# ── Shiprocket Login (stored in DB, not read from env) ────────
# Set once at Admin Panel > Settings > Shipping.
