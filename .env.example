# ============================================================
# BLUEFIFTH E-COMMERCE — Environment Variables Template
#
# Copy to .env and fill in real values.
# Add .env to .gitignore — NEVER commit real credentials.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_URL=http://localhost/ecommerce-project
APP_NAME=bluefifth
APP_ENV=development         # development | production
APP_DEBUG=false

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=ecommerce_referral_db
DB_USER=root
DB_PASS=                    # use a strong password in production

# ── MSG91 OTP ────────────────────────────────────────────────
# Sign up at https://msg91.com — Auth Key from API > Auth Key
# Leave MSG91_AUTH_KEY empty or set to "dev" for mock mode
# (mock mode: any phone accepted, OTP 123456 always works)
# DLT template registration required for production in India.
MSG91_AUTH_KEY=dev
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=BLUEFTH

# ── Google OAuth (DEPRECATED) ─────────────────────────────────
# Google Sign-In has been removed. Phone-OTP is used instead.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Razorpay ─────────────────────────────────────────────────
# Use rzp_live_* keys for production
RAZORPAY_KEY_ID=rzp_test_
RAZORPAY_KEY_SECRET=
RAZORPAY_MODE=test           # test | live

# ── SendinBlue (Brevo) Email ─────────────────────────────────
SENDINBLUE_API_KEY=
SENDINBLUE_FROM_EMAIL=info@yourdomain.com
SENDINBLUE_FROM_NAME=Your Site Name

# ── Shiprocket ───────────────────────────────────────────────
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=

# ── Admin ────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
# Run setup-admin-password.php to set the admin bcrypt hash
